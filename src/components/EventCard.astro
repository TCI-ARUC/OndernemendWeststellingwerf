---
// Agenda-kaart: datumblok + label + titel + aanmeldknop.
interface Props {
  day: string;
  month: string;
  label: string;
  labelBg: string;
  labelColor: string;
  title: string;
  text: string;
  ctaLabel: string;
  ctaHref: string;
  ctaPrimary?: boolean;
}
const { day, month, label, labelBg, labelColor, title, text, ctaLabel, ctaHref, ctaPrimary = false } = Astro.props;
---

<div class="event" data-card>
  <div class="row">
    <div class="date">
      <span class="day">{day}</span>
      <span class="mon">{month}</span>
    </div>
    <span class="label" style={`background:${labelBg};color:${labelColor}`}>{label}</span>
  </div>
  <div>
    <h3>{title}</h3>
    <p>{text}</p>
  </div>
  <a href={ctaHref} class:list={['cta', { primary: ctaPrimary }]}>{ctaLabel}</a>
</div>

<style>
  .event {
    background: var(--wit);
    border: 1px solid var(--rand);
    border-radius: var(--radius-card);
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .row { display: flex; align-items: center; gap: 14px; }
  .date {
    background: var(--ink);
    color: #fff;
    border-radius: 13px;
    width: 60px;
    height: 64px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    flex: none;
  }
  .day { font-weight: 800; font-size: 26px; line-height: 1; }
  .mon { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; }
  .label {
    font-weight: 700;
    font-size: 12.5px;
    padding: 5px 11px;
    border-radius: var(--radius-pill);
  }
  h3 { font-weight: 700; font-size: 21px; margin: 0 0 4px; color: var(--ink); }
  p { font-size: 14.5px; color: var(--tekst-dim); margin: 0; line-height: 1.5; }
  .cta {
    margin-top: auto;
    text-decoration: none;
    text-align: center;
    background: var(--wit);
    color: var(--ink);
    border: 1.5px solid rgba(41, 35, 92, .16);
    font-weight: 700;
    font-size: 15px;
    padding: 11px;
    border-radius: 11px;
  }
  .cta.primary {
    background: var(--magenta);
    color: #fff;
    border-color: transparent;
  }
</style>
