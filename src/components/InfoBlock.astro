---
// Lila info-blok met dashed rand + info-icoon. Bedoeld voor toelichtingen
// (bijv. toekomstige automatische koppelingen).
---
<div class="info">
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--ink-500)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
  <p><slot /></p>
</div>

<style>
  .info {
    background: rgba(198, 196, 213, .28);
    border: 1px dashed rgba(41, 35, 92, .2);
    border-radius: 16px;
    padding: 22px 26px;
    display: flex;
    gap: 14px;
    align-items: center;
  }
  .info svg { flex: none; }
  .info p {
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--ink-500);
    margin: 0;
  }
</style>
