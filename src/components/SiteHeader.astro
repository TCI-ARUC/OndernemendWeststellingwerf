---
// Gedeelde sticky header. `active` markeert de actieve nav-link.
type NavKey = 'home' | 'overons' | 'agenda' | 'leden' | 'lidmaatschap' | 'nieuws' | 'fonds' | 'bedrijventerreinen' | 'ondernemersfonds';

interface Props {
  active?: NavKey;
}
const { active } = Astro.props;

import instellingen from '../data/instellingen.json';
const LEDENPORTAAL = instellingen.ledenportaalUrl;

// De drie samenwerkende stichtingen/fondsen staan gegroepeerd onder "Stichtingen".
const stichtingen = [
  { key: 'bedrijventerreinen', label: 'Bedrijventerreinen', sub: 'Parkmanagement Wolvega', href: '/bedrijventerreinen' },
  { key: 'ondernemersfonds', label: 'Ondernemersfonds', sub: 'SOW · reclamebelasting', href: '/ondernemersfonds' },
  { key: 'fonds', label: 'Stimuleringsfonds', sub: 'Ondernemend Veuruut', href: '/fonds' },
] as const;

const nav = [
  { key: 'home', label: 'Home', href: '/' },
  { key: 'overons', label: 'Over ons', href: '/over-ons' },
  { key: 'agenda', label: 'Agenda', href: '/agenda' },
  { key: 'leden', label: 'Leden', href: '/leden' },
  { key: 'lidmaatschap', label: 'Lidmaatschap', href: '/lidmaatschap' },
  { key: 'nieuws', label: 'Nieuws', href: '/nieuws' },
] as const;

const stichtingActive = stichtingen.some((s) => s.key === active);
---

<header class="site-header" data-header>
  <div class="ow-container bar">
    <a href="/" class="brand" aria-label="Ondernemend Weststellingwerf — home">
      <img src="/img/mark-ow.png" alt="" width="488" height="979" class="brand-mark" />
      <span class="brand-words">
        <span class="brand-l1">Ondernemend</span>
        <span class="brand-l2">Weststellingwerf</span>
      </span>
    </a>

    <nav class="nav">
      {nav.map((item) => (
        <a href={item.href} class:list={['nav-link', { active: active === item.key }]}>
          {item.label}
        </a>
      ))}
      <div class="has-menu">
        <button type="button" class:list={['nav-link', 'nav-trigger', { active: stichtingActive }]} aria-haspopup="true" aria-expanded="false">
          Stichtingen
          <svg class="caret" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="dropdown" role="menu">
          {stichtingen.map((s) => (
            <a href={s.href} role="menuitem" class:list={['dd-link', { active: active === s.key }]}>
              <span class="dd-label">{s.label}</span>
              <span class="dd-sub">{s.sub}</span>
            </a>
          ))}
        </div>
      </div>
    </nav>

    <div class="actions">
      <a href={LEDENPORTAAL} target="_blank" rel="noopener" class="login">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
        Inloggen
      </a>
      <a href="/lidmaatschap" class="cta-pill">Word lid</a>
      <button type="button" class="menu-toggle" aria-label="Menu" aria-expanded="false" aria-controls="mobiel-menu" data-toggle>
        <svg class="i-open" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        <svg class="i-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
  </div>

  <div class="mobile-menu" id="mobiel-menu" data-menu>
    <nav class="m-nav">
      {nav.map((item) => (
        <a href={item.href} class:list={['m-link', { active: active === item.key }]}>
          {item.label}
        </a>
      ))}
      <div class="m-group-label">Stichtingen</div>
      {stichtingen.map((s) => (
        <a href={s.href} class:list={['m-link', 'm-sublink', { active: active === s.key }]}>
          {s.label}
          <span class="m-sub">{s.sub}</span>
        </a>
      ))}
    </nav>
    <div class="m-actions">
      <a href={LEDENPORTAAL} target="_blank" rel="noopener" class="m-login">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
        Inloggen
      </a>
      <a href="/lidmaatschap" class="m-cta">Word lid</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(250, 248, 243, .85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(41, 35, 92, .10);
  }
  .bar {
    height: 74px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 11px;
    text-decoration: none;
    flex: none;
    min-width: 0;
  }
  .brand-mark { display: block; height: 38px; width: auto; }
  .brand-words {
    display: flex;
    flex-direction: column;
    line-height: 1.02;
    font-weight: 800;
    color: var(--ink);
    letter-spacing: -.01em;
  }
  .brand-l1 { font-size: 18px; }
  .brand-l2 { font-size: 18px; font-weight: 600; color: var(--ink-500); }

  .nav {
    display: flex;
    align-items: center;
    gap: 4px;
    font-weight: 600;
    font-size: 15.5px;
    white-space: nowrap;
  }
  .nav-link {
    text-decoration: none;
    color: var(--ink-500);
    padding: 9px 13px;
    border-radius: 9px;
  }
  .nav-link:hover { color: var(--ink); }
  .nav-link.active {
    color: var(--ink);
    font-weight: 800;
    background: rgba(149, 27, 129, .08);
  }

  /* Stichtingen-dropdown (desktop) */
  .has-menu { position: relative; }
  .nav-trigger {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font: inherit;
    font-weight: 600;
    background: none;
    border: none;
    cursor: pointer;
  }
  .nav-trigger .caret { transition: transform .18s ease; }
  .has-menu:hover .nav-trigger,
  .has-menu:focus-within .nav-trigger { color: var(--ink); }
  .has-menu:hover .caret,
  .has-menu:focus-within .caret { transform: rotate(180deg); }
  .dropdown {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    min-width: 250px;
    background: var(--wit);
    border: 1px solid rgba(41, 35, 92, .12);
    border-radius: 16px;
    box-shadow: 0 22px 48px -20px rgba(41, 35, 92, .45);
    padding: 8px;
    display: flex;
    flex-direction: column;
    gap: 2px;
    opacity: 0;
    visibility: hidden;
    transform: translateY(6px);
    transition: opacity .16s ease, transform .16s ease, visibility .16s;
  }
  /* onzichtbare brug zodat de muis de gap niet "verliest" */
  .has-menu::after {
    content: '';
    position: absolute;
    top: 100%;
    right: 0;
    width: 250px;
    height: 10px;
  }
  .has-menu:hover .dropdown,
  .has-menu:focus-within .dropdown,
  .has-menu.open .dropdown {
    opacity: 1;
    visibility: visible;
    transform: none;
  }
  .dd-link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    padding: 10px 12px;
    border-radius: 11px;
  }
  .dd-link:hover { background: var(--paper); }
  .dd-link.active { background: rgba(149, 27, 129, .08); }
  .dd-label { font-weight: 700; font-size: 15px; color: var(--ink); }
  .dd-sub { font-size: 12.5px; color: var(--tekst-dim); margin-top: 1px; }

  .actions {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: none;
  }
  .login {
    text-decoration: none;
    color: var(--ink);
    font-weight: 600;
    font-size: 15px;
    padding: 9px 6px;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .cta-pill {
    text-decoration: none;
    background: var(--magenta);
    color: #fff;
    font-weight: 700;
    font-size: 15px;
    padding: 11px 20px;
    border-radius: var(--radius-pill);
    box-shadow: 0 6px 18px -6px rgba(149, 27, 129, .6);
    white-space: nowrap;
  }

  /* Hamburger-knop: alleen op mobiel */
  .menu-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 0;
    border: 1px solid rgba(41, 35, 92, .16);
    border-radius: 12px;
    background: var(--wit);
    color: var(--ink);
    cursor: pointer;
  }
  .menu-toggle .i-close { display: none; }
  .menu-toggle[aria-expanded='true'] .i-open { display: none; }
  .menu-toggle[aria-expanded='true'] .i-close { display: block; }

  /* Mobiel uitklapmenu */
  .mobile-menu {
    display: none;
    border-top: 1px solid rgba(41, 35, 92, .10);
    background: var(--paper);
    padding: 10px 24px 18px;
  }
  .m-nav { display: flex; flex-direction: column; }
  .m-link {
    text-decoration: none;
    color: var(--ink-500);
    font-weight: 600;
    font-size: 17px;
    padding: 13px 8px;
    border-radius: 10px;
    border-bottom: 1px solid rgba(41, 35, 92, .06);
  }
  .m-link.active { color: var(--ink); font-weight: 800; background: rgba(149, 27, 129, .08); }
  .m-group-label {
    font-weight: 700;
    font-size: 12.5px;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--tekst-dim);
    padding: 16px 8px 6px;
  }
  .m-sublink { display: flex; flex-direction: column; gap: 2px; padding-left: 18px; }
  .m-sublink .m-sub { font-size: 13px; font-weight: 600; color: var(--tekst-dim); }
  .m-actions { display: flex; flex-direction: column; gap: 10px; margin-top: 16px; }
  .m-login {
    text-decoration: none;
    color: var(--ink);
    font-weight: 700;
    font-size: 16px;
    padding: 12px 8px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .m-cta {
    text-decoration: none;
    text-align: center;
    background: var(--magenta);
    color: #fff;
    font-weight: 700;
    font-size: 16px;
    padding: 14px;
    border-radius: var(--radius-pill);
    box-shadow: var(--schaduw-magenta);
  }

  /* 8 nav-items passen alleen comfortabel op brede schermen; daaronder hamburger */
  @media (max-width: 1140px) {
    .nav { display: none; }
    .actions .login,
    .actions .cta-pill { display: none; }
    .menu-toggle { display: inline-flex; }
    .mobile-menu.open { display: block; }
  }
</style>

<script>
  const header = document.querySelector('[data-header]');
  const btn = header?.querySelector('[data-toggle]');
  const menu = header?.querySelector('[data-menu]');
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('open');
    btn.setAttribute('aria-expanded', String(Boolean(open)));
  });

  // Stichtingen-dropdown: houd aria-expanded gelijk aan de hover/focus-staat
  // (het openen zelf gebeurt via CSS) en sta klikken/Escape toe.
  const hasMenu = header?.querySelector('.has-menu');
  const trigger = hasMenu?.querySelector('.nav-trigger');
  if (hasMenu && trigger) {
    const sync = (open: boolean) => trigger.setAttribute('aria-expanded', String(open));
    hasMenu.addEventListener('mouseenter', () => sync(true));
    hasMenu.addEventListener('mouseleave', () => sync(false));
    hasMenu.addEventListener('focusin', () => sync(true));
    hasMenu.addEventListener('focusout', () => sync(false));
    trigger.addEventListener('click', () => {
      const open = hasMenu.classList.toggle('open');
      sync(open);
    });
    hasMenu.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Escape') {
        hasMenu.classList.remove('open');
        sync(false);
        (trigger as HTMLElement).blur();
      }
    });
  }
</script>
