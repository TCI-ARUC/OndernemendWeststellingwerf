---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import Base from '../../layouts/Base.astro';
import { nieuwsKleur, datumLang } from '../../lib/taxonomy';

export const getStaticPaths = (async () => {
  const alle = await getCollection('nieuws');
  return alle.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await render(entry);
const kleur = nieuwsKleur(entry.data.category);
---

<Base title={`${entry.data.title} — Ondernemend Weststellingwerf`} description={entry.data.excerpt} active="nieuws">
  <article class="wrap">
    <a href="/nieuws" class="back">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
      Terug naar nieuws
    </a>
    <span class="cat" style={`color:${kleur}`}>{entry.data.category}</span>
    <h1>{entry.data.title}</h1>
    <div class="date">{datumLang(entry.data.pubDate)}</div>

    {entry.data.image && <img src={entry.data.image} alt="" class="hero-img" />}

    <div class="prose">
      <Content />
    </div>
  </article>
</Base>

<style>
  .wrap { max-width: 760px; margin: 0 auto; padding: 56px 24px 64px; }
  .back {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    text-decoration: none;
    color: var(--ink-500);
    font-weight: 700;
    font-size: 14.5px;
    margin-bottom: 26px;
  }
  .back:hover { color: var(--magenta); }
  .cat { display: block; font-weight: 700; font-size: 13px; letter-spacing: .04em; text-transform: uppercase; }
  h1 {
    font-weight: 800;
    font-size: 40px;
    line-height: 1.08;
    letter-spacing: -.025em;
    margin: 10px 0 12px;
    color: var(--ink);
    text-wrap: balance;
  }
  .date { font-size: 14.5px; color: var(--tekst-dim); font-weight: 600; margin-bottom: 28px; }
  .hero-img { width: 100%; border-radius: var(--radius-card-lg); margin-bottom: 28px; display: block; }
  .prose :global(p) { font-size: 17.5px; line-height: 1.7; color: var(--tekst); margin: 0 0 18px; }
  .prose :global(h2) { font-weight: 800; font-size: 24px; letter-spacing: -.02em; color: var(--ink); margin: 32px 0 12px; }
  .prose :global(a) { color: var(--magenta); }
  @media (max-width: 520px) { h1 { font-size: 32px; } }
</style>
