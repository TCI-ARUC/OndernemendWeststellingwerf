---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import PrijsCard from '../components/PrijsCard.astro';

const SIGNUP = 'https://app.clubcollect.com/signup/249679c4-b120-42ac-8221-ab1bd5cccc36';

const basisFeatures = [
  'Belangenbehartiging — jouw stem richting gemeente en provincie',
  'Stemrecht — meebeslissen tijdens de ALV',
  'Wekelijkse nieuwsbrief met regionaal nieuws',
  'Collectieve voordelen via mantelcontracten (Parkmanagement)',
];
const netwerkFeatures = [
  'Gratis toegang tot alle borrels, bedrijfsbezoeken en het jaarfeest',
  'Toegang tot de netwerk-app (ledenlijst)',
  '1× per jaar een zakenrelatie meenemen',
];
const groeiFeatures = [
  'PR-service: wij interviewen je en plaatsen een artikel op site & socials (1× p.j.)',
  'Kennis Academy: 2 exclusieve workshops (o.a. AI, marketing, HR)',
  'Expert-status: label "Uitgelicht" op je profiel',
  'Social Boost: wij delen jouw nieuws op onze kanalen',
];

const stappen = [
  { n: '1', title: 'Vul het formulier in', text: 'Kies je pakket en vul je bedrijfsgegevens in. Duurt twee minuten.' },
  { n: '2', title: 'Bevestig & betaal', text: 'Contributie loopt via automatische incasso. Geen gedoe achteraf.' },
  { n: '3', title: 'Welkom!', text: 'Je staat in het smoelenboek en bent welkom op alle bijeenkomsten.' },
];
---

<Base title="Lidmaatschap — Ondernemend Weststellingwerf" active="lidmaatschap">
  <PageHero
    kicker="Lidmaatschap"
    title="Kies wat bij jouw bedrijf past"
    lead="Drie lidmaatschappen, één doel: samen sterker ondernemen. Bedragen per jaar, exclusief btw."
    center maxWidth={880} />

  {/* PRICING */}
  <section class="prijs-grid">
    <PrijsCard
      tier="Basis" price="€75" blurb="Voor wie de regio steunt en profiteert van een sterk ondernemersklimaat."
      ctaLabel="Word lid" ctaHref={SIGNUP} ctaExternal features={basisFeatures} />
    <PrijsCard
      tier="Connect" price="€325" blurb="Voor wie actief wil verbinden en zaken wil doen tijdens onze events."
      ctaLabel="Word Connect-lid" ctaHref={SIGNUP} ctaExternal featured
      featuresIntro="Alles uit Basis, plus:" features={netwerkFeatures} />
    <PrijsCard
      tier="Groei" price="€450" period="/ jaar (introductietarief)"
      blurb="Voor wie marketing, kennis en zichtbaarheid wil uitbesteden."
      ctaLabel="Word lid" ctaHref={SIGNUP} ctaExternal
      featuresIntro="Alles uit Connect, plus:" features={groeiFeatures} />
  </section>

  {/* STAPPEN */}
  <section class="wrap-920 pad">
    <h2 class="center-h2">Zo word je lid</h2>
    <div class="stappen">
      {stappen.map((s) => (
        <div class="card stap">
          <div class="num">{s.n}</div>
          <h3>{s.title}</h3>
          <p>{s.text}</p>
        </div>
      ))}
    </div>
  </section>

  {/* CTA */}
  <section class="wrap-920 cta-wrap">
    <div class="card cta">
      <h2>Twijfel je nog?</h2>
      <p>Loop een keer binnen bij een borrel of stel je vraag. We denken graag met je mee.</p>
      <div class="cta-row">
        <a href={SIGNUP} target="_blank" rel="noopener" class="btn-primary">Direct inschrijven</a>
        <a href="/contact" class="btn-ghost">Stel een vraag</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .prijs-grid { max-width: 1100px; margin: 0 auto; padding: 18px 24px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; align-items: start; }
  .wrap-920 { max-width: 920px; margin: 0 auto; padding-left: 24px; padding-right: 24px; }
  .pad { padding-top: 38px; padding-bottom: 38px; }
  .card { background: var(--wit); border: 1px solid var(--rand); border-radius: 22px; }

  .center-h2 { font-weight: 800; font-size: 28px; letter-spacing: -.02em; margin: 0 0 22px; color: var(--ink); text-align: center; }
  .stappen { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .stap { border-radius: 18px; padding: 26px; }
  .stap .num { width: 38px; height: 38px; border-radius: 50%; background: var(--ink); color: #fff; font-weight: 800; display: flex; align-items: center; justify-content: center; margin-bottom: 14px; }
  .stap h3 { font-weight: 800; font-size: 18px; margin: 0 0 6px; color: var(--ink); }
  .stap p { font-size: 14.5px; line-height: 1.55; color: var(--tekst); margin: 0; }

  .cta-wrap { padding: 14px 24px 64px; }
  .cta { padding: 40px; text-align: center; border-radius: 22px; }
  .cta h2 { font-weight: 800; font-size: 26px; margin: 0 0 10px; color: var(--ink); }
  .cta p { font-size: 16.5px; color: var(--tekst); margin: 0 auto 22px; max-width: 480px; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary {
    text-decoration: none;
    background: var(--magenta);
    color: #fff;
    font-weight: 700;
    font-size: 16px;
    padding: 14px 26px;
    border-radius: var(--radius-pill);
    box-shadow: var(--schaduw-magenta);
  }
  .btn-ghost {
    text-decoration: none;
    background: var(--wit);
    color: var(--ink);
    border: 1.5px solid rgba(41, 35, 92, .16);
    font-weight: 700;
    font-size: 16px;
    padding: 13px 24px;
    border-radius: var(--radius-pill);
  }

  @media (max-width: 940px) {
    .prijs-grid { grid-template-columns: 1fr; max-width: 460px; }
  }
  @media (max-width: 760px) {
    .stappen { grid-template-columns: 1fr; }
  }
</style>
