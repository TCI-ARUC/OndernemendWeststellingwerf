---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import data from '../data/bedrijventerreinen.json';

const PM_EMAIL = data.contact.email;
const PM_TEL = data.contact.telefoon;

const { terreinen, doelen, documenten, formulieren, bestuur } = data;

// Teksten uit bedrijventerreinen.json; vormgeving (kleur/icoon) hoort bij de code.
const dienstStijlen = [
  { accent: 'var(--teal)', bg: 'rgba(22,168,146,.12)', color: 'var(--teal-tekst)', icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>' },
  { accent: 'var(--oranje)', bg: 'rgba(240,144,0,.13)', color: 'var(--oranje-tekst)', icon: '<polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/>' },
  { accent: 'var(--magenta)', bg: 'rgba(149,27,129,.10)', color: 'var(--magenta)', icon: '<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>' },
  { accent: 'var(--rood)', bg: 'rgba(200,32,42,.10)', color: 'var(--rood)', icon: '<rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>' },
];
const diensten = data.diensten.map((d, i) => ({ ...d, ...dienstStijlen[i % dienstStijlen.length] }));
---

<Base
  title="Bedrijventerreinen Wolvega — Ondernemend Weststellingwerf"
  description="Stichting Parkmanagement Bedrijventerreinen Wolvega bewaakt de kwaliteit van de Wolvegaster bedrijventerreinen en zet collectieve initiatieven op rond veiligheid, onderhoud en inkoop."
  active="bedrijventerreinen">
  <PageHero
    kicker="Parkmanagement"
    title="Bedrijventerreinen Wolvega"
    lead="Stichting Parkmanagement Bedrijventerreinen Wolvega (SPBW) bewaakt de kwaliteit van de Wolvegaster bedrijventerreinen en zet collectieve initiatieven op voor de ondernemers — van veiligheid tot onderhoud en gezamenlijke inkoop."
    fan maxWidth={900} />

  {/* TERREINEN + KVO */}
  <section class="wrap pad">
    <div class="terreinen">
      <div class="terreinen-head">
        <span class="kvo">KVO-B 2025–2028</span>
        <h2>Vijf gecertificeerde terreinen</h2>
        <p>Schipsloot, Noord-West, De Plantage, Heerendeel en een deel van Van der Valk dragen samen het <strong>Keurmerk Veilig Ondernemen – Bedrijventerrein</strong> (sinds 2022): een erkenning voor terreinen waar samenwerking de veiligheid aantoonbaar verbetert.</p>
      </div>
      <ul class="chips">
        {terreinen.map((t) => <li>{t}</li>)}
      </ul>
    </div>
  </section>

  {/* DIENSTEN */}
  <section class="wrap pad-top">
    <div class="head-center">
      <h2>Wat het je oplevert</h2>
      <p>Door samen op te trekken regelen we zaken die je alleen niet (zo voordelig) voor elkaar krijgt.</p>
    </div>
    <div class="grid">
      {diensten.map((d) => (
        <div class="card">
          <div class="topbar" style={`background:${d.accent}`}></div>
          <div class="icon" style={`background:${d.bg};color:${d.color}`}>
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={d.icon} />
          </div>
          <h3>{d.titel}</h3>
          <p>{d.tekst}</p>
        </div>
      ))}
    </div>
  </section>

  {/* DOELSTELLINGEN */}
  <section class="wrap pad-top">
    <div class="doelen card">
      <h2>Onze doelstellingen</h2>
      <p class="doelen-intro">Het doel van Parkmanagement is het structureel verbeteren van het ondernemersklimaat op de bedrijventerreinen.</p>
      <ul class="checklist">
        {doelen.map((d) => (
          <li>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--teal)" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            {d}
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* DOCUMENTEN & FORMULIEREN */}
  <section class="wrap pad-top">
    <div class="docs-grid">
      <div class="card docblock">
        <h2>Documenten</h2>
        <ul class="filelist">
          {documenten.map((f) => (
            <li>
              <a href={f.href} target="_blank" rel="noopener">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                <span>{f.label}</span>
                <em>{f.meta}</em>
              </a>
            </li>
          ))}
        </ul>
      </div>
      <div class="card docblock">
        <h2>Aanmelden & interesse</h2>
        <ul class="filelist">
          {formulieren.map((f) => (
            <li>
              <a href={f.href} target="_blank" rel="noopener">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                <span>{f.label}</span>
                <em>{f.meta}</em>
              </a>
            </li>
          ))}
        </ul>
        <p class="docnote">Interesse om mee te doen aan een collectief? Vul het betreffende formulier in en stuur het naar <a href={`mailto:${PM_EMAIL}`}>{PM_EMAIL}</a>.</p>
      </div>
    </div>
  </section>

  {/* BESTUUR & CONTACT */}
  <section class="wrap pad-top">
    <div class="card org">
      <h2>Bestuur &amp; contact</h2>
      <p class="org-intro">Het Parkmanagement wordt gerund door een bestuur van ondernemers van de terreinen zelf.</p>
      <ul class="bestuur">
        {bestuur.map((b) => (
          <li><span class="naam">{b.naam}</span><span class="rol">{b.rol}</span></li>
        ))}
      </ul>
      <div class="org-contact">
        Vragen over het Parkmanagement? Neem contact op met secretaris <strong>{data.contact.contactpersoon}</strong> —
        <a href={`tel:${data.contact.telefoonLink}`}>{PM_TEL}</a> · <a href={`mailto:${PM_EMAIL}`}>{PM_EMAIL}</a>
      </div>
    </div>
  </section>

  {/* CTA */}
  <section class="wrap cta-wrap">
    <div class="cta-band">
      <div class="cta-fan" aria-hidden="true"></div>
      <div class="cta-inner">
        <h2>Gevestigd op een Wolvegaster bedrijventerrein?</h2>
        <p>Profiteer mee van de collectieve afspraken en denk mee over een veilig, vitaal terrein.</p>
        <a href={`mailto:${PM_EMAIL}`} class="cta-btn">Mail het Parkmanagement
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  .wrap { max-width: 1100px; margin: 0 auto; padding-left: 24px; padding-right: 24px; }
  .pad { padding-top: 30px; padding-bottom: 16px; }
  .pad-top { padding-top: 24px; padding-bottom: 16px; }
  .card { background: var(--wit); border: 1px solid var(--rand); border-radius: 22px; }

  .terreinen { padding: 34px 36px; }
  .terreinen-head .kvo {
    display: inline-block;
    background: rgba(22, 168, 146, .12);
    color: var(--teal-tekst);
    font-weight: 700;
    font-size: 12.5px;
    letter-spacing: .03em;
    padding: 5px 12px;
    border-radius: var(--radius-pill);
    margin-bottom: 12px;
  }
  .terreinen-head h2 { font-weight: 800; font-size: 26px; letter-spacing: -.02em; margin: 0 0 10px; color: var(--ink); }
  .terreinen-head p { font-size: 16px; line-height: 1.6; color: var(--tekst); margin: 0 0 18px; max-width: 720px; }
  .chips { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 10px; }
  .chips li {
    background: var(--paper);
    border: 1px solid var(--rand);
    color: var(--ink);
    font-weight: 700;
    font-size: 14px;
    padding: 8px 14px;
    border-radius: var(--radius-pill);
  }

  .head-center { text-align: center; max-width: 600px; margin: 8px auto 28px; }
  .head-center h2 { font-weight: 800; font-size: 30px; letter-spacing: -.02em; margin: 0 0 10px; color: var(--ink); }
  .head-center p { font-size: 16.5px; line-height: 1.55; color: var(--tekst); margin: 0; }

  .grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px; }
  .grid .card { padding: 28px; position: relative; overflow: hidden; }
  .topbar { position: absolute; top: 0; left: 0; right: 0; height: 4px; }
  .icon { width: 50px; height: 50px; border-radius: 14px; display: flex; align-items: center; justify-content: center; margin-bottom: 18px; }
  .grid h3 { font-weight: 700; font-size: 21px; margin: 0 0 8px; color: var(--ink); }
  .grid p { font-size: 15.5px; line-height: 1.55; color: var(--tekst); margin: 0; }

  /* Doelstellingen */
  .doelen { padding: 32px 36px; }
  .doelen h2 { font-weight: 800; font-size: 24px; letter-spacing: -.02em; margin: 0 0 8px; color: var(--ink); }
  .doelen-intro { font-size: 16px; line-height: 1.6; color: var(--tekst); margin: 0 0 18px; }
  .checklist { list-style: none; padding: 0; margin: 0; display: grid; grid-template-columns: 1fr 1fr; gap: 12px 24px; }
  .checklist li { display: flex; gap: 10px; font-size: 15.5px; color: var(--ink-500); align-items: flex-start; }
  .checklist svg { flex: none; margin-top: 2px; }

  /* Documenten & formulieren */
  .docs-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
  .docblock { padding: 30px 32px; }
  .docblock h2 { font-weight: 800; font-size: 22px; letter-spacing: -.02em; margin: 0 0 16px; color: var(--ink); }
  .filelist { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
  .filelist a {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: var(--ink);
    background: var(--paper);
    border: 1px solid var(--rand);
    border-radius: 12px;
    padding: 12px 14px;
    font-weight: 600;
    font-size: 14.5px;
  }
  .filelist a:hover { border-color: var(--magenta); color: var(--magenta); }
  .filelist svg { flex: none; color: var(--magenta); }
  .filelist span { flex: 1; line-height: 1.35; }
  .filelist em { font-style: normal; font-size: 11.5px; font-weight: 700; color: var(--tekst-dim); text-transform: uppercase; letter-spacing: .04em; flex: none; }
  .docnote { font-size: 14px; line-height: 1.55; color: var(--tekst-dim); margin: 16px 0 0; }
  .docnote a { color: var(--magenta); }

  /* Bestuur & contact */
  .org { padding: 32px 36px; }
  .org h2 { font-weight: 800; font-size: 24px; letter-spacing: -.02em; margin: 0 0 8px; color: var(--ink); }
  .org-intro { font-size: 16px; line-height: 1.6; color: var(--tekst); margin: 0 0 18px; }
  .bestuur { list-style: none; padding: 0; margin: 0 0 20px; display: grid; grid-template-columns: 1fr 1fr; gap: 12px 24px; }
  .bestuur li { display: flex; flex-direction: column; padding-bottom: 12px; border-bottom: 1px solid var(--rand); }
  .bestuur .naam { font-weight: 800; font-size: 15.5px; color: var(--ink); }
  .bestuur .rol { font-size: 13.5px; color: var(--tekst-dim); }
  .org-contact { font-size: 15px; line-height: 1.6; color: var(--ink-500); }
  .org-contact a { color: var(--magenta); text-decoration: none; font-weight: 700; }

  .cta-wrap { padding: 34px 24px 64px; }
  .cta-band {
    background: linear-gradient(120deg, #951B81, #29235C 70%);
    border-radius: 24px;
    padding: 46px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .cta-fan {
    position: absolute;
    left: -50px;
    bottom: -90px;
    width: 280px;
    height: 280px;
    border-radius: 50%;
    background: conic-gradient(from 160deg, #F09000 0 8deg, transparent 8deg 16deg, #16A892 16deg 24deg, transparent 24deg 32deg, #C8202A 32deg 40deg, transparent 40deg 90deg);
    opacity: .3;
    mask: radial-gradient(circle, transparent 32%, #000 33%);
  }
  .cta-inner { position: relative; z-index: 1; }
  .cta-inner h2 { font-weight: 800; font-size: 28px; letter-spacing: -.02em; margin: 0 0 12px; color: #fff; }
  .cta-inner p { font-size: 16.5px; color: #E7DEF3; margin: 0 auto 24px; max-width: 520px; }
  .cta-btn {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    background: #fff;
    color: var(--ink);
    font-weight: 800;
    font-size: 16.5px;
    padding: 15px 28px;
    border-radius: var(--radius-pill);
  }

  @media (max-width: 760px) {
    .grid, .docs-grid, .checklist, .bestuur { grid-template-columns: 1fr; }
    .terreinen, .doelen, .docblock, .org { padding: 28px 24px; }
  }
</style>
