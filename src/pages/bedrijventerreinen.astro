---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';

const terreinen = ['Schipsloot', 'Noord-West', 'De Plantage', 'Heerendeel', 'Van der Valk (deels)'];

const diensten = [
  {
    accent: 'var(--teal)', bg: 'rgba(22,168,146,.12)', color: 'var(--teal-tekst)',
    title: 'Veiligheid & KVO-B',
    text: 'Collectieve beveiliging via G4S, anoniem misdaad melden en korte lijnen met de wijkagent en toezichthouders. Het Keurmerk Veilig Ondernemen borgt dat je hier veilig onderneemt.',
    icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  },
  {
    accent: 'var(--oranje)', bg: 'rgba(240,144,0,.13)', color: 'var(--oranje-tekst)',
    title: 'Infrastructuur & onderhoud',
    text: 'We bewaken het onderhoud van de openbare ruimte, de bewegwijzering en goed zichtbare huisnummers — zodat de terreinen er verzorgd bij liggen en goed vindbaar zijn.',
    icon: '<polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/><line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/>',
  },
  {
    accent: 'var(--magenta)', bg: 'rgba(149,27,129,.10)', color: 'var(--magenta)',
    title: 'Collectieve inkoop',
    text: 'Samen sterker inkopen: gezamenlijke afvalinzameling via Renewi (met een flinke CO₂-besparing) en gedeelde veiligheidsmiddelen. Schaalvoordeel voor iedereen op het terrein.',
    icon: '<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>',
  },
  {
    accent: 'var(--rood)', bg: 'rgba(200,32,42,.10)', color: 'var(--rood)',
    title: 'Digitaal & ondersteuning',
    text: 'Een cybersecurity IT-scan en de MKB Cyber Alarmcentrale houden je digitaal weerbaar. Daarnaast ondersteuning bij BHV en de RI&E (risico-inventarisatie).',
    icon: '<rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
  },
];
---

<Base
  title="Bedrijventerreinen Wolvega — Ondernemend Weststellingwerf"
  description="Stichting Parkmanagement Bedrijventerreinen Wolvega bewaakt de kwaliteit van de Wolvegaster bedrijventerreinen en zet collectieve initiatieven op rond veiligheid, onderhoud en inkoop."
  active="bedrijventerreinen">
  <PageHero
    kicker="Parkmanagement"
    title="Bedrijventerreinen Wolvega"
    lead="Stichting Parkmanagement Bedrijventerreinen Wolvega (SPBW) bewaakt de kwaliteit van de Wolvegaster bedrijventerreinen en zet collectieve initiatieven op voor de ondernemers — van veiligheid tot onderhoud en gezamenlijke inkoop."
    fan maxWidth={900} />

  {/* TERREINEN + KVO */}
  <section class="wrap pad">
    <div class="terreinen">
      <div class="terreinen-head">
        <span class="kvo">KVO-B 2025–2028</span>
        <h2>Vijf gecertificeerde terreinen</h2>
        <p>Schipsloot, Noord-West, De Plantage, Heerendeel en een deel van Van der Valk dragen samen het <strong>Keurmerk Veilig Ondernemen – Bedrijventerrein</strong>: een erkenning voor terreinen waar samenwerking de veiligheid aantoonbaar verbetert.</p>
      </div>
      <ul class="chips">
        {terreinen.map((t) => <li>{t}</li>)}
      </ul>
    </div>
  </section>

  {/* DIENSTEN */}
  <section class="wrap pad-top">
    <div class="head-center">
      <h2>Wat het je oplevert</h2>
      <p>Door samen op te trekken regelen we zaken die je alleen niet (zo voordelig) voor elkaar krijgt.</p>
    </div>
    <div class="grid">
      {diensten.map((d) => (
        <div class="card">
          <div class="topbar" style={`background:${d.accent}`}></div>
          <div class="icon" style={`background:${d.bg};color:${d.color}`}>
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={d.icon} />
          </div>
          <h3>{d.title}</h3>
          <p>{d.text}</p>
        </div>
      ))}
    </div>
  </section>

  {/* CTA */}
  <section class="wrap cta-wrap">
    <div class="cta-band">
      <div class="cta-fan" aria-hidden="true"></div>
      <div class="cta-inner">
        <h2>Gevestigd op een Wolvegaster bedrijventerrein?</h2>
        <p>Profiteer mee van de collectieve afspraken en denk mee over een veilig, vitaal terrein.</p>
        <a href="/contact" class="cta-btn">Neem contact op
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  .wrap { max-width: 1100px; margin: 0 auto; padding-left: 24px; padding-right: 24px; }
  .pad { padding-top: 30px; padding-bottom: 16px; }
  .pad-top { padding-top: 30px; padding-bottom: 16px; }

  .terreinen {
    background: var(--wit);
    border: 1px solid var(--rand);
    border-radius: 22px;
    padding: 34px 36px;
  }
  .terreinen-head .kvo {
    display: inline-block;
    background: rgba(22, 168, 146, .12);
    color: var(--teal-tekst);
    font-weight: 700;
    font-size: 12.5px;
    letter-spacing: .03em;
    padding: 5px 12px;
    border-radius: var(--radius-pill);
    margin-bottom: 12px;
  }
  .terreinen-head h2 { font-weight: 800; font-size: 26px; letter-spacing: -.02em; margin: 0 0 10px; color: var(--ink); }
  .terreinen-head p { font-size: 16px; line-height: 1.6; color: var(--tekst); margin: 0 0 18px; max-width: 720px; }
  .chips { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 10px; }
  .chips li {
    background: var(--paper);
    border: 1px solid var(--rand);
    color: var(--ink);
    font-weight: 700;
    font-size: 14px;
    padding: 8px 14px;
    border-radius: var(--radius-pill);
  }

  .head-center { text-align: center; max-width: 600px; margin: 8px auto 28px; }
  .head-center h2 { font-weight: 800; font-size: 30px; letter-spacing: -.02em; margin: 0 0 10px; color: var(--ink); }
  .head-center p { font-size: 16.5px; line-height: 1.55; color: var(--tekst); margin: 0; }

  .grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px; }
  .card {
    background: var(--wit);
    border: 1px solid var(--rand);
    border-radius: 20px;
    padding: 28px;
    position: relative;
    overflow: hidden;
  }
  .topbar { position: absolute; top: 0; left: 0; right: 0; height: 4px; }
  .icon { width: 50px; height: 50px; border-radius: 14px; display: flex; align-items: center; justify-content: center; margin-bottom: 18px; }
  .card h3 { font-weight: 700; font-size: 21px; margin: 0 0 8px; color: var(--ink); }
  .card p { font-size: 15.5px; line-height: 1.55; color: var(--tekst); margin: 0; }

  .cta-wrap { padding: 34px 24px 64px; }
  .cta-band {
    background: linear-gradient(120deg, #951B81, #29235C 70%);
    border-radius: 24px;
    padding: 46px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .cta-fan {
    position: absolute;
    left: -50px;
    bottom: -90px;
    width: 280px;
    height: 280px;
    border-radius: 50%;
    background: conic-gradient(from 160deg, #F09000 0 8deg, transparent 8deg 16deg, #16A892 16deg 24deg, transparent 24deg 32deg, #C8202A 32deg 40deg, transparent 40deg 90deg);
    opacity: .3;
    mask: radial-gradient(circle, transparent 32%, #000 33%);
  }
  .cta-inner { position: relative; z-index: 1; }
  .cta-inner h2 { font-weight: 800; font-size: 28px; letter-spacing: -.02em; margin: 0 0 12px; color: #fff; }
  .cta-inner p { font-size: 16.5px; color: #E7DEF3; margin: 0 auto 24px; max-width: 520px; }
  .cta-btn {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    background: #fff;
    color: var(--ink);
    font-weight: 800;
    font-size: 16.5px;
    padding: 15px 28px;
    border-radius: var(--radius-pill);
  }

  @media (max-width: 760px) {
    .grid { grid-template-columns: 1fr; }
    .terreinen { padding: 28px 24px; }
  }
</style>
